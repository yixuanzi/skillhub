DATABASE_URL=sqlite:///./data/skillhub.db
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=["http://localhost:5173"]
#用来自定义生成skillhub的URL
SKILLHUB_URL=http://localhost:5173
SKILL_HOST="0.0.0.0"
SKILL_PORT=8000
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
GATEWAY_FORCE_PLAINTEXT=false
# 设为 true 时跳过远程服务 TLS 证书合法性校验（仅用于内部/自签证书环境）
SKIP_VERIFY=false
# 审计日志最大保留天数，超出部分每天 23:00 自动清除（默认 120 天）
AUDIT_LOG_RETENTION_DAYS=120